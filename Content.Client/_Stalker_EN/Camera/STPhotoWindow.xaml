<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'st-photo-window-title'}"
                      MinSize="500 430">
    <BoxContainer Orientation="Vertical" Margin="5">
        <!-- Photo display area -->
        <PanelContainer VerticalExpand="True" Margin="0 0 0 5">
            <TextureRect Name="PhotoTexture"
                         Stretch="KeepAspectCentered"
                         HorizontalExpand="True"
                         VerticalExpand="True" />
            <Label Name="LoadingLabel"
                   Text="{Loc 'st-photo-loading'}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        </PanelContainer>

        <!-- Metadata -->
        <BoxContainer Orientation="Horizontal" Margin="0 5 0 0">
            <Label Name="PhotographerLabel"
                   HorizontalExpand="True" />
            <Label Name="TimeLabel" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
